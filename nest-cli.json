    "user": {
      "type": "library",
      "root": "libs/user",
      "entryFile": "index",
      "sourceRoot": "libs/user/src",
      "compilerOptions": { "tsConfigPath": "libs/user/tsconfig.lib.json" }
    }
  }
}
