{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": { "deleteOutDir": false, "webpack": true, "plugins": ["@nestjs/swagger"] },
  "projects": {
    "app-config": {
      "type": "library",
      "root": "libs/app-config",
      "entryFile": "index",
      "sourceRoot": "libs/app-config/src",
      "compilerOptions": { "tsConfigPath": "libs/app-config/tsconfig.lib.json" }
    },
    "app-env": {
      "type": "library",
      "root": "libs/app-env",
      "entryFile": "index",
      "sourceRoot": "libs/app-env/src",
      "compilerOptions": { "tsConfigPath": "libs/app-env/tsconfig.lib.json" }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": { "tsConfigPath": "libs/auth/tsconfig.lib.json" }
    },
    "cat": {
      "type": "library",
      "root": "libs/cat",
      "entryFile": "index",
      "sourceRoot": "libs/cat/src",
      "compilerOptions": { "tsConfigPath": "libs/cat/tsconfig.lib.json" }
    },
    "database-mongodb": {
      "type": "library",
      "root": "libs/database-mongodb",
      "entryFile": "index",
      "sourceRoot": "libs/database-mongodb/src",
      "compilerOptions": { "tsConfigPath": "libs/database-mongodb/tsconfig.lib.json" }
    },
    "health": {
      "type": "library",
      "root": "libs/health",
      "entryFile": "index",
      "sourceRoot": "libs/health/src",
      "compilerOptions": { "tsConfigPath": "libs/health/tsconfig.lib.json" }
    },
    "image": {
      "type": "library",
      "root": "libs/image",
      "entryFile": "index",
      "sourceRoot": "libs/image/src",
      "compilerOptions": { "tsConfigPath": "libs/image/tsconfig.lib.json" }
    },
    "local-file": {
      "type": "library",
      "root": "libs/local-file",
      "entryFile": "index",
      "sourceRoot": "libs/local-file/src",
      "compilerOptions": { "tsConfigPath": "libs/local-file/tsconfig.lib.json" }
    },
    "redis": {
      "type": "library",
      "root": "libs/redis",
      "entryFile": "index",
      "sourceRoot": "libs/redis/src",
      "compilerOptions": { "tsConfigPath": "libs/redis/tsconfig.lib.json" }
